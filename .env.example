# ============================================================
# LexAI — Multimodal Courtroom Intelligence Platform
# Environment Variables Template
# Copy to .env and fill in your actual values
# ============================================================

# ---- LLM API Keys ----
OPENAI_API_KEY=your_openai_key_here
GROQ_API_KEY=your_groq_key_here

# Note: Groq is FREE at https://console.groq.com
# Note: OpenAI needed only for GPT-4V image analysis
# Note: All text generation uses Groq (free tier available)

# ---- Database ----
DATABASE_URL=postgresql://admin:secret@localhost:5432/lexai
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lexai
DB_USER=admin
DB_PASSWORD=secret

# ---- App Configuration ----
APP_ENV=development
API_KEY=lexai_secret_key_change_in_production
LOG_LEVEL=INFO
MAX_UPLOAD_MB=100
SECRET_KEY=your_secret_key_change_in_production

# ---- Optional: Azure OpenAI (alternative to OpenAI) ----
# AZURE_OPENAI_API_KEY=your_azure_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ---- Optional: HuggingFace ----
# HUGGINGFACE_API_KEY=your_hf_key_here
